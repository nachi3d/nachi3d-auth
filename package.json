{
  "name": "nachi3d-auth",
  "version": "0.8.0",
  "private": true,
  "description": "Nachi3D Certify — NFC/QR-backed authentication registry for Nachi3D resin figurines.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "verify": "npm run lint && npm run typecheck && npm run build",
    "test:e2e": "playwright test",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset --linked",
    "db:seed": "tsx scripts/seed-remote.ts",
    "dev:signin": "tsx scripts/dev-signin.ts",
    "rotate-tokens": "tsx scripts/rotate-tokens.ts",
    "sign": "tsx scripts/sign-token.ts",
    "fetch:fonts": "tsx scripts/fetch-fonts.ts",
    "purge:cards": "tsx scripts/purge-card-cache.ts"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.49.0",
    "next": "^15.5.0",
    "next-intl": "^3.26.0",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^22.10.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "^16.4.0",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.5.0",
    "pdf-parse": "^2.4.5",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
