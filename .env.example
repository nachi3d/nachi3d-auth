# Public site URL (used in HMAC URL generation, Open Graph, etc.)
NEXT_PUBLIC_SITE_URL=https://verify.nachi3d.com

# Supabase project credentials
# Project URL — public, safe to expose
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Anon key — public, safe to expose; RLS protects the data
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — SERVER ONLY, NEVER exposed to the client
# Used by lib/supabase/admin.ts for verification_logs inserts
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# HMAC secret for NFC verification token signing
# Generate locally with: openssl rand -hex 32
# Server-side only. Rotating this invalidates every existing chip.
HMAC_SECRET=replace-me-with-openssl-rand-hex-32
